# ACE-Step local API server
# Authenticates requests to the local ACE-Step inference server
ACEMUSIC_API_KEY=

# Base URL for the ACE-Step API (local or remote proxy)
ACEMUSIC_BASE_URL=

# Default ACE-Step model variant (turbo, base, sft, xl-base, xl-sft, xl-turbo)
# Leave blank to use the server's built-in default
ACEMUSIC_DEFAULT_MODEL=

# URL of the local ACE-Step REST API server (default: http://localhost:8001)
ACESTEP_LOCAL_URL=http://localhost:8001

# API key securing the ACE-Step server process itself
ACESTEP_API_KEY=

# RunPod management API key (for starting/stopping remote GPU pods)
RUNPOD_API_KEY=

# RunPod serverless endpoint ID for the remote ACE-Step deployment
RUNPOD_ENDPOINT_ID=

# ElevenLabs cloud music generation (used as fallback when ACE-Step is unavailable)
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs output format (default: mp3_44100_128)
# Options: mp3_44100_128, mp3_44100_192 (Creator+), pcm_44100 (Pro+), opus_48000_128
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# App secret key (used for session signing, CSRF, etc.)
SECRET_KEY=

# Database connection URL (SQLite for light dev, PostgreSQL for production)
DATABASE_URL=
