# ACE-Step local API server
# Authenticates requests to the local ACE-Step inference server
ACEMUSIC_API_KEY=

# Base URL for the ACE-Step API (local or remote proxy)
ACEMUSIC_BASE_URL=

# URL of the local ACE-Step REST API server (default: http://localhost:8001)
ACESTEP_LOCAL_URL=http://localhost:8001

# API key securing the ACE-Step server process itself
ACESTEP_API_KEY=

# RunPod management API key (for starting/stopping remote GPU pods)
RUNPOD_API_KEY=

# RunPod serverless endpoint ID for the remote ACE-Step deployment
RUNPOD_ENDPOINT_ID=

# App secret key (used for session signing, CSRF, etc.)
SECRET_KEY=

# Database connection URL (SQLite for light dev, PostgreSQL for production)
DATABASE_URL=
